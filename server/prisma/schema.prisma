generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  plan                String    @default("free")
  planExpiresAt       DateTime? @map("plan_expires_at")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  profile      Profile?
  universities University[]
  sops         SOP[]
  documents    Document[]
  lors         LetterOfRecommendation[]

  @@map("users")
}

model Profile {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @unique @map("user_id")
  studyLevel               String?  @map("study_level") // 'undergraduate', 'masters', 'phd', 'other'
  gpa                      Float?
  gpaScale                 String   @default("us_4") @map("gpa_scale")
  satScore                 Int?     @map("sat_score")
  actScore                 Int?     @map("act_score")
  greVerbal                Int?     @map("gre_verbal")
  greQuant                 Int?     @map("gre_quant")
  greWriting               Float?   @map("gre_writing")
  toeflScore               Int?     @map("toefl_score")
  ieltsScore               Float?   @map("ielts_score")
  undergraduateInstitution String?  @map("undergraduate_institution")
  undergraduateMajor       String?  @map("undergraduate_major")
  graduationYear           Int?     @map("graduation_year")
  workExperienceYears      Int?     @map("work_experience_years")
  fieldOfStudy             String?  @map("field_of_study")
  careerGoals              String?  @map("career_goals")
  researchInterests        String?  @map("research_interests")
  extracurriculars         String?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model University {
  id                  Int       @id @default(autoincrement())
  userId              Int       @map("user_id")
  name                String
  program             String
  degreeLevel         String    @default("masters") @map("degree_level") // 'undergraduate', 'masters', 'phd', 'certificate', 'other'
  websiteUrl          String?   @map("website_url")
  category            String
  applicationDeadline DateTime? @map("application_deadline")
  status              String    @default("not_started")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  reminder30SentAt  DateTime? @map("reminder_30_sent_at")
  reminder14SentAt  DateTime? @map("reminder_14_sent_at")
  reminder7SentAt   DateTime? @map("reminder_7_sent_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sops         SOP[]
  documentTags DocumentTag[]

  @@map("universities")
}

model SOP {
  id           Int       @id @default(autoincrement())
  universityId Int       @map("university_id")
  userId       Int       @map("user_id")
  title        String
  content      String
  wordCount    Int       @default(0) @map("word_count")
  status       String    @default("draft")
  version      Int       @default(1)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  university University    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  critiques  SOPCritique[]
  shareLinks SOPShareLink[]

  @@map("sops")
}

model SOPShareLink {
  id        Int       @id @default(autoincrement())
  sopId     Int       @map("sop_id")
  token     String    @unique
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  sop      SOP                @relation(fields: [sopId], references: [id], onDelete: Cascade)
  comments SOPReviewComment[]

  @@map("sop_share_links")
}

model SOPReviewComment {
  id            Int      @id @default(autoincrement())
  shareLinkId   Int      @map("share_link_id")
  reviewerName  String   @map("reviewer_name")
  comment       String
  createdAt     DateTime @default(now()) @map("created_at")

  shareLink SOPShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@map("sop_review_comments")
}

model Document {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  name         String
  docType      String   @map("doc_type") // 'transcript','test_scores','recommendation','resume','financial','passport','other'
  fileName     String   @map("file_name")
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type")
  filePath     String   @map("file_path")
  createdAt    DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags DocumentTag[]

  @@map("documents")
}

model DocumentTag {
  documentId   Int @map("document_id")
  universityId Int @map("university_id")

  document   Document   @relation(fields: [documentId],   references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@id([documentId, universityId])
  @@map("document_tags")
}

model SOPCritique {
  id                Int      @id @default(autoincrement())
  sopId             Int      @map("sop_id")
  overallAssessment String?  @map("overall_assessment")
  authenticityScore Int?     @map("authenticity_score")
  specificityScore  Int?     @map("specificity_score")
  clarityScore      Int?     @map("clarity_score")
  impactScore       Int?     @map("impact_score")
  strengths         String?
  weaknesses        String?
  suggestions       String?
  rawCritiqueText   String?  @map("raw_critique_text")
  aiLikelihood      Int?     @map("ai_likelihood")
  aiReasoning       String?  @map("ai_reasoning")
  createdAt         DateTime @default(now()) @map("created_at")

  sop SOP @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@map("sop_critiques")
}

model LetterOfRecommendation {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  recommenderName   String    @map("recommender_name")
  recommenderEmail  String?   @map("recommender_email")
  relationship      String    // "professor", "employer", "mentor", "other"
  status            String    @default("not_asked") // "not_asked", "asked", "confirmed", "submitted"
  universityIds     String?   @map("university_ids") // JSON array of university IDs
  deadline          DateTime?
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("letters_of_recommendation")
}

model UniversityRequirements {
  id              Int      @id @default(autoincrement())
  universityName  String   @map("university_name")
  program         String
  matchedProgram  String?  @map("matched_program")
  requirementsJson String  @map("requirements_json")
  sourceUrl       String?  @map("source_url")
  sourceType      String   @default("ai_knowledge") @map("source_type")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([universityName, program])
  @@map("university_requirements")
}
